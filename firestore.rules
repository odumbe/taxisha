rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — each user manages their own profile
    match /users/{userId} {
      // Anyone can read basic user info (needed for ride matching, ratings)
      allow read: if request.auth != null;

      // Users can write only their own document
      // Drivers: can update their own profile (but verificationStatus is admin-only)
      // Admin: managed separately below
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['verificationStatus']));
      allow delete: if false; // users are soft-deleted or disabled

      // Driver documents subcollection (PII — restricted)
      match /driverDocs/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rides collection
    match /rides/{rideId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.driverId
            || request.auth.uid == resource.data.passengerId);
      allow delete: if false;
    }

    // Ratings collection
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.raterId;
      allow update, delete: if false;
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.passengerId
            || request.auth.uid == resource.data.driverId);
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Penalties & appeals
    match /penalties/{penaltyId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.userId);
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow delete: if false;

      match /appeals/{appealId} {
        allow read, write: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // Admin access — any user with role == 'admin' can manage all data
    match /{document=**} {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
