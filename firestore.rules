rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — each user manages their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['verificationStatus']);
      allow delete: if false;

      match /driverDocs/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // RideRequests collection
    match /rideRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.passengerId
            || request.resource.data.driverId == request.auth.uid
            || (resource.data.status == 'pending'
                && request.resource.data.rejectedBy.hasAny([request.auth.uid])));
      allow delete: if false;
    }

    // Rides collection
    match /rides/{rideId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.driverId
            || request.auth.uid == resource.data.passengerId);
      allow delete: if false;
    }

    // Ratings collection
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.raterId;
      allow update, delete: if false;
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.passengerId
            || request.auth.uid == resource.data.driverId);
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Penalties & appeals
    match /penalties/{penaltyId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.userId);
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow delete: if false;

      match /appeals/{appealId} {
        allow read, write: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }
  }
}
